---
# metadata for table ajax
---
{% if site.data.theme.data-child-objects == true %}
{%- assign items = site.data[site.metadata] | where_exp: 'item','item["Object name"]' -%}
{% else %}
{%- assign items = site.data[site.metadata] | where_exp: 'item','item["Object name"]' | where_exp: 'item','item.parentid == nil' -%}
{% endif %}
{%- assign fields = site.data.config-table | map: 'field' -%}
{ "objects": [
{%- for item in items -%}[ {% for f in fields %}{% if item[f] %}{{ item[f] | jsonify }}{% else %}"n/a"{% endif %},{% endfor %} {% if item.parentid %}{{ '/item.html' | relative_url | append: '?id=' | append: item.parentid | append: '#' | append: item["Object name"] | jsonify }}{% else %}{{ '/item.html' | relative_url | append: '?id=' | append: item["Object name"] | jsonify }}{% endif %} ]{% unless forloop.last %},{% endunless %}
{% endfor %}
] }
